                {
                    "name": "Create Event (Admin)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const responseData = pm.response.json();",
                                    "if(responseData._id) {",
                                    "    pm.environment.set(\"event_id\", responseData._id);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Tech Conference 2024\",\n    \"description\": \"A massive conference for developers\",\n    \"date\": \"2024-12-01\",\n    \"location\": \"San Francisco, CA\",\n    \"category\": \"Technology\",\n    \"totalSeats\": 100,\n    \"ticketPrice\": 500,\n    \"image\": \"https://images.unsplash.com/photo-1540575467063-178a50c2df87\"\n}"
                        },
