        {
            "name": "Bookings",
            "item": [
                {
                    "name": "Send Booking OTP Request",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
