                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"paymentStatus\": \"paid\"\n}"
                        },
                        "url": {
                            "raw": "http://localhost:5000/api/bookings/{{booking_id}}/confirm",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "5000",
                            "path": [
                                "api",
                                "bookings",
                                "{{booking_id}}",
